{
  "version": 2,
  "buildCommand": "cd cypto-pulse && npm run build",
  "outputDirectory": "cypto-pulse/dist",
  "rewrites": [
    {
      "source": "/api/coingecko/(.*)",
      "destination": "/api/coingecko-proxy?path=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
